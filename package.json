{
  "name": "duartec-web",
  "version": "1.0.0",
  "private": true,
  "description": "Sitio web profesional de Duartec Instalaciones Informáticas - Soluciones integrales en informática, videovigilancia, sonido y electricidad en Burgos",
  "keywords": [
    "informática",
    "videovigilancia",
    "sonido",
    "electricidad",
    "burgos",
    "instalaciones",
    "nextjs",
    "typescript"
  ],
  "author": "Duartec Instalaciones Informáticas",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "analyze": "cross-env ANALYZE=true next build",
    "sitemap": "next-sitemap",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "@types/react-dom": "^18.0.0",
    "contentlayer": "^0.3.4",
    "framer-motion": "^10.0.0",
    "lucide-react": "^0.263.0",
    "next": "^14.2.32",
    "next-intl": "^3.0.0",
    "next-seo": "^6.0.0",
    "next-sitemap": "^4.0.0",
    "postcss": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/react": "^14.0.0",
    "@types/react": "19.1.12",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "15.5.2",
    "husky": "^8.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.40.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
